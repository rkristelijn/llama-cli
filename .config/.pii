# .pii — PII detection patterns for check-pii.sh
# Prevents accidental commits of personal/sensitive information
# Note: Only scans src/, scripts/, docs/ — not .git/ or .config/

# Hostnames (internal infrastructure)
apsnlmac4050
apsnlmac4050\.local

# Personal directories (from /git/hub/personal/*)
burnout-herstel
family-relationships
financials
friendships
household-chores
journal
career

# Personal names (avoid hardcoding in code/docs)
zani

# Dutch BSN (11-digit number pattern: XXX.XX.XXX or XXXXXXXXXXX)
\b[0-9]{3}\.[0-9]{2}\.[0-9]{3}\b
\b[0-9]{11}\b

# Phone numbers (Dutch: +31 or 06 followed by digits)
\+31\s?[0-9]{1,3}\s?[0-9]{3,4}\s?[0-9]{4}
\b06\s?[0-9]{8}\b
\b06-[0-9]{8}\b

# Bank account numbers (IBAN: NL + 18 digits)
NL[0-9]{2}\s?[A-Z]{4}\s?[0-9]{10}
NL[0-9]{2}[A-Z]{4}[0-9]{10}

# Credit card patterns (16 digits, spaces/dashes optional)
\b[0-9]{4}[\s\-]?[0-9]{4}[\s\-]?[0-9]{4}[\s\-]?[0-9]{4}\b

# Internal hostnames (network infrastructure)
friday\.local
pepper\.local
jarvis\.local
ultron\.local
roz-desktop
10\.0\.0\.[0-9]+

# Work username and absolute paths
nlrxk0145
/Users/nlrxk0145

# Employer identifiers
apsnl
theapsgroup
the aps group
aps group

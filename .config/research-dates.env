# research-dates.env — Last-researched dates for scripts that depend on external knowledge.
# Format: SCRIPT_KEY=YYYY-MM-DD
# Update the date after completing a research cycle for that topic.
# check-research-freshness.sh warns when any entry is >30 days old.
#
# To update after research: sed -i '' "s/^KEY=.*/KEY=$(date +%Y-%m-%d)/" .config/research-dates.env

# AI slop detection patterns (check-slop.sh)
SLOP_DETECTION=2026-05-13

# AI model benchmarks and recommendations (model-guide, bench-models)
MODEL_GUIDE=2026-05-13

# Security tool versions and CVE patterns (sast-*, osv-scan)
SECURITY_TOOLS=2026-05-13

# Shell portability patterns (check-portability.sh)
PORTABILITY=2026-05-13

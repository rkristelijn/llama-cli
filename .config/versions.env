# versions.env — single source of truth for development tool versions
#
# Read by: Makefile, scripts/setup.sh, .github/workflows/ci.yml
# C++ library versions are pinned separately in CMakeLists.txt (FetchContent GIT_TAG).
#
# @see docs/adr/adr-026-version-pinning.md — rationale
# @see docs/adr/adr-44-tidy-boilerplate.md — ADR for build boilerplate

# Build tools
CMAKE_VERSION=4.3
CCACHE_VERSION=4.9.1
JQ_VERSION=1.7

# LLVM tools (clang-format, clang-tidy)
# brew: `brew install llvm` provides both
# apt:  needs LLVM apt repo, installs as clang-format-$VER / clang-tidy-$VER
LLVM_VERSION=19

# Quality tools
CPPCHECK_VERSION=2.20
PMCCABE_VERSION=2.8
DOXYGEN_VERSION=1.17.0
SHELLCHECK_VERSION=0.11.0
CLOC_VERSION=2.02

# SAST tools
# semgrep: brew/pipx on mac, pipx or container on linux (not in apt)
# gitleaks: brew and apt both work
# zsteg: Ruby gem for steganography detection
# trivy: IaC security scanner
# trufflehog: secret verification scanner (brew or direct download)
# grype: vulnerability scanner for images/filesystems (brew or curl installer)
# syft: SBOM generator (brew or curl installer)
# osv-scanner: Google OSV vulnerability scanner (brew or direct download)
# checkov: IaC policy scanner (pipx)
SEMGREP_VERSION=1.157.0
GITLEAKS_VERSION=8.30.1
ZSTEG_VERSION=0.2.13
TRIVY_VERSION=0.70.0
TRUFFLEHOG_VERSION=3.95.2
GRYPE_VERSION=0.112.0
SYFT_VERSION=1.44.0
OSV_SCANNER_VERSION=2.3.6
CHECKOV_VERSION=3.2.520

# Linters
# yamllint: brew and apt both work (Python-based but brew/apt handle it transparently)
YAMLLINT_VERSION=1.38.0
# rumdl: Rust markdown linter — single binary, no Node/Python needed
# brew on mac, direct download on linux
RUMDL_VERSION=0.1.87

# Release tools
# git-cliff: brew on mac, direct download on linux (not in apt)
GIT_CLIFF_VERSION=2.13.1

# GitHub Actions (SHA pins — used by workflows, verified by check-versions)
# Format: ACTION_<NAME>_SHA=<commit-sha> and ACTION_<NAME>_VERSION=<tag>
ACTION_CHECKOUT_SHA=34e114876b0b11c390a56381ad16ebd13914f8d5
ACTION_CHECKOUT_VERSION=v4.3.1
ACTION_DOWNLOAD_ARTIFACT_SHA=87c55149d96e628cc2ef7e6fc2aab372015aec85
ACTION_DOWNLOAD_ARTIFACT_VERSION=v4.1.3
ACTION_UPLOAD_ARTIFACT_SHA=ea165f8d65b6e75b540449e92b4886f43607fa02
ACTION_UPLOAD_ARTIFACT_VERSION=v4.6.2
ACTION_GH_RELEASE_SHA=3bb12739c298aeb8a4eeaf626c5b8d85266b0e65
ACTION_GH_RELEASE_VERSION=v2.6.2
ACTION_PATHS_FILTER_SHA=de90cc6fb38fc0963ad72b210f1f284cd68cea36
ACTION_PATHS_FILTER_VERSION=v3.0.2
ACTION_CODECOV_SHA=75cd11691c0faa626561e295848008c8a7dddffe
ACTION_CODECOV_VERSION=v5.5.4

# Coverage (lcov/gcov/bc are system packages, not pinned)
# Runtime (ollama installed via curl installer, not pinned here)

# Mutation testing
# mull: LLVM-based mutation testing — brew tap on mac, cloudsmith repo on linux
MULL_VERSION=19
